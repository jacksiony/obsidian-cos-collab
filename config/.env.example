# Obsidian-COS-OpenClaw 环境配置示例
# 复制为 .env 并根据实际情况修改

# COS 配置（必须）
COS_SECRET_ID="AKIDxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
COS_SECRET_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
COS_BUCKET="obsidian-1250000000"
COS_REGION="ap-guangzhou"

# 路径配置（可选，默认值见脚本）
# COS_VAULT_ROOT="/obsidian_vault/"
# COS_INBOX_PATH="/obsidian_vault/06AI_workspace/00AI_Inbox/"
# COS_DRAFTS_PATH="/obsidian_vault/06AI_workspace/01AI_Drafts/"

# 系统路径（可选）
# OPENCLAW_SYSTEM_BASE="$HOME/openclaw-system"
# MIRROR_DIR="$OPENCLAW_SYSTEM_BASE/mirror"
# PROPOSALS_DIR="$OPENCLAW_SYSTEM_BASE/proposals"
# PUBLISHED_DIR="$OPENCLAW_SYSTEM_BASE/published"
# REJECTED_DIR="$OPENCLAW_SYSTEM_BASE/rejected"
# SYNC_LOG="$OPENCLAW_SYSTEM_BASE/logs/sync.log"
# PUBLISH_LOG="$OPENCLAW_SYSTEM_BASE/logs/publish.log"
